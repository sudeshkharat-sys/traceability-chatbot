# ===========================================
# Environment Configuration
# ===========================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# Usage:
#   1. cp .env.example .env
#   2. Edit .env with your actual credentials
#   3. NEVER commit .env to git (it contains secrets!)
#
# This .env file works for both:
#   - Docker Deployment: docker-compose.yml reads this file
#   - Local Development: app/config/config.py reads this file
#
# FOR LOCAL DEVELOPMENT: Change these values:
#   POSTGRES_HOST=localhost (instead of postgres)
#   NEO4J_URL=neo4j://127.0.0.1:7687 (instead of neo4j://neo4j:7687)
# ===========================================

# ===========================================
# AZURE OPENAI CONFIGURATION
# ===========================================
# Get these from your Azure Portal > Azure OpenAI Service
# REQUIRED: You must fill these in for the app to work
AZURE_API_KEY=your_azure_api_key_here
AZURE_CHAT_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-chat-deployment
AZURE_EMBEDDING_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-embedding-deployment
AZURE_GPT5_ENDPOINT=

# ===========================================
# DATABASE PASSWORDS & CREDENTIALS
# ===========================================
# SECURITY: Change these default passwords in production!
# These are used by both Docker containers and application code

# PostgreSQL Credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=chatbot
POSTGRES_HOST=postgres  # For Docker | Use 'localhost' for local dev
POSTGRES_PORT=5432

# Neo4j Credentials
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme_neo4j_password
NEO4J_URL=neo4j://neo4j:7687  # For Docker | Use 'neo4j://127.0.0.1:7687' for local dev
NEO4J_DATABASE=neo4j

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_RELOAD=true
SERVER_LOG_LEVEL=debug

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5000,http://127.0.0.1:5000,http://localhost

# Session Configuration
SESSION_SECRET=changeme_session_secret_key

# Agent Configuration
MAX_CHAT_HISTORY=10
QUERY_TIMEOUT_SECONDS=30
