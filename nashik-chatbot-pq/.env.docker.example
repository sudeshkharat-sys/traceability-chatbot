# ===========================================
# Docker Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values
# Usage: cp .env.docker.example .env

# ===========================================
# AZURE OPENAI CONFIGURATION
# ===========================================
# Get these from your Azure Portal > Azure OpenAI Service
AZURE_API_KEY=your_azure_api_key_here
AZURE_CHAT_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-chat-deployment
AZURE_EMBEDDING_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-embedding-deployment
AZURE_GPT5_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-gpt5-deployment

# ===========================================
# DATABASE CONFIGURATION (Docker)
# ===========================================
# These are pre-configured for Docker Compose
# Only change if you modify docker-compose.yml

# Neo4j Configuration
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=chatbot

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
HOST=0.0.0.0
PORT=5000
DEBUG=true
LOG_LEVEL=INFO
