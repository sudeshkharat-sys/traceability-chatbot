# ===========================================
# Local Development Environment Configuration
# ===========================================
# NOTE: For Docker deployments, use /.env.docker.example instead
#       This file is for local development only
#
# Usage for local development:
#   1. Copy this file: cp app/config/.env.example app/config/.env
#   2. Fill in your actual values
#   3. Run the app locally: python main.py
#
# Usage for Docker:
#   1. Use .env.docker.example at the project root
#   2. Copy it: cp .env.docker.example .env
#   3. The .env file will be automatically mounted into the container
# ===========================================

# AZURE OPENAI (Required)
AZURE_API_KEY=
AZURE_CHAT_ENDPOINT=
AZURE_EMBEDDING_ENDPOINT=
AZURE_GPT5_ENDPOINT=

# NEO4J (Required)
NEO4J_URL=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# POSTGRESQL (Required)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=chatbot

# APPLICATION SETTINGS
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_RELOAD=true
SERVER_LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5000

# Session Configuration
SESSION_SECRET=change-me-in-production

# Agent Configuration
MAX_CHAT_HISTORY=10
QUERY_TIMEOUT_SECONDS=30
